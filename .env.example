# CloudMail Open Links - API Sync + Web Viewer

# Optional: password for /admin UI (if set, login required)
ADMIN_PASSWORD=admin123

# Base public URL used when generating share/open links (for display/copy)
# e.g. https://mailview.example.com
PUBLIC_BASE_URL=http://localhost:3118

# MongoDB connection (required for Docker / production)
MONGODB_URI=mongodb://localhost:27017/cloudmail_open_links
# For docker-compose use: mongodb://mongo:27017/cloudmail_open_links

# === Optional: 默认上游邮件接口，用于后台直接批量创建邮箱 ===
MAIL_PROVIDER_API_TOKEN=
MAIL_PROVIDER_API_BASE_URL=https://mail.example.com/api/public
MAIL_PROVIDER_WAF_BYPASS_TOKEN=
MAIL_PROVIDER_WAF_BYPASS_HEADER=X-WAF-BYPASS

# For production one-click/PM2
PORT=3118
HOSTNAME=0.0.0.0
